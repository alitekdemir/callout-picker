{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES6",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "sourceMap": false,
    "inlineSourceMap": false,
    "inlineSources": false,
    "lib": ["ES6", "DOM"],
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*"]
}
